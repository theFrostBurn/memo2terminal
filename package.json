{
  "name": "memo2terminal",
  "displayName": "Memo2Terminal",
  "description": "Explorer와 Source Control 영역의 메모를 터미널로 전송하는 VS Code 확장",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theFrostBurn/memo2terminal.git"
  },
  "version": "0.0.5",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "memo2terminal.view",
          "name": "Memo to Terminal",
          "type": "webview"
        }
      ],
      "scm": [
        {
          "id": "memo2terminal.scmView",
          "name": "Memo to Terminal",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "memo2terminal.focusView",
        "title": "Memo2Terminal: 메모장 뷰 포커스"
      }
    ],
    "configuration": {
      "title": "Memo2Terminal",
      "properties": {
        "memo2terminal.shortcuts.send": {
          "type": "string",
          "default": "",
          "scope": "window",
          "description": "메모 전송 단축키입니다. 비워두면 운영체제별 기본값을 사용합니다. 예: Ctrl+Enter, Cmd+Enter"
        },
        "memo2terminal.shortcuts.historyPrevious": {
          "type": "string",
          "default": "",
          "scope": "window",
          "description": "이전 히스토리로 이동하는 단축키입니다. 비워두면 운영체제별 기본값을 사용합니다. 예: Ctrl+ArrowUp, Cmd+ArrowUp"
        },
        "memo2terminal.shortcuts.historyNext": {
          "type": "string",
          "default": "",
          "scope": "window",
          "description": "다음 히스토리로 이동하는 단축키입니다. 비워두면 운영체제별 기본값을 사용합니다. 예: Ctrl+ArrowDown, Cmd+ArrowDown"
        },
        "memo2terminal.shortcuts.historyList": {
          "type": "string",
          "default": "",
          "scope": "window",
          "description": "히스토리 목록을 여는 단축키입니다. 비워두면 운영체제별 기본값을 사용합니다. 예: Ctrl+H, Cmd+Ctrl+H"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "tsc -w -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.3"
  }
}
